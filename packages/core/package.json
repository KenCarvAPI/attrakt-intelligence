{
  "name": "@attrakt/core",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "seed:demo": "tsx prisma/seed-demo.ts",
    "member:merge": "tsx src/scripts/merge-member.ts",
    "test": "vitest run && pnpm test:integration",
    "test:watch": "vitest",
    "test:integration": "node --import tsx --test src/services/merge-member.test.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.9.0",
    "discord.js": "^14.14.1",
    "octokit": "^3.1.2",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "twitter-api-v2": "^1.15.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prisma": "^5.9.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^2.1.8"
  }
}
