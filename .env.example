# Attrakt Intelligence - Environment Variables Example
# Copy this file to .env and fill in your actual values

# ============================================
# Application Configuration
# ============================================
NODE_ENV=development
DEFAULT_CLIENT_ID=default
PORT=3001
GITHUB_WEBHOOK_PORT=3002

# ============================================
# Database (REQUIRED)
# ============================================
# PostgreSQL connection string with TimescaleDB extension
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://attrakt:attrakt_dev@localhost:5432/attrakt

# ============================================
# Redis (REQUIRED)
# ============================================
# Redis connection string
# Format: redis://host:port or redis://:password@host:port
REDIS_URL=redis://localhost:6379

# ============================================
# Discord Integration (REQUIRED for Discord features)
# ============================================
# Get these from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# ============================================
# GitHub Integration (REQUIRED for GitHub features)
# ============================================
# Option 1: Personal Access Token
GITHUB_TOKEN=your_github_personal_access_token_here
# OR Option 2: GitHub App (use these instead of GITHUB_TOKEN)
# GITHUB_APP_ID=your_github_app_id_here
# GITHUB_PRIVATE_KEY=your_github_private_key_here

# Webhook secret for verifying GitHub webhook requests
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here

# OAuth credentials (optional, for user authentication)
GITHUB_CLIENT_ID=your_github_oauth_client_id_here
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret_here

# ============================================
# Twitter Integration (REQUIRED for Twitter features)
# ============================================
# Get these from https://developer.twitter.com
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
TWITTER_CLIENT_ID=your_twitter_client_id_here
TWITTER_CLIENT_SECRET=your_twitter_client_secret_here

# Comma-separated list of Twitter accounts to track
# Example: TWITTER_TRACKED_ACCOUNTS=account1,account2,account3
TWITTER_TRACKED_ACCOUNTS=

# Polling interval in milliseconds (default: 900000 = 15 minutes)
TWITTER_POLL_INTERVAL_MS=900000

# ============================================
# Discourse Integration (governance forum ingestion)
# ============================================
# The forum base URL is configured PER CLIENT (PlatformConfig.config.baseUrl via
# `pnpm client:create --discourse-url ...`). API key + username can be set per
# client (PlatformConfig.credentials) or globally here. Read endpoints are public
# on most forums, so credentials are optional for read-only ingestion.
DISCOURSE_API_KEY=your_discourse_api_key_here
DISCOURSE_API_USERNAME=your_discourse_api_username_here

# Polling interval in milliseconds (default: 900000 = 15 minutes)
DISCOURSE_POLL_INTERVAL_MS=900000

# Comma-separated category slugs treated as governance (distinct scoring/digest signal)
DISCOURSE_GOVERNANCE_CATEGORIES=governance,proposals,dao

# ============================================
# Anthropic / Claude AI (REQUIRED for AI features)
# ============================================
# Get API key from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================
# Slack Integration (OPTIONAL - for alerts and notifications)
# ============================================
# Create webhook at https://api.slack.com/apps
# Format: https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ============================================
# Email Integration (OPTIONAL - for daily digests)
# ============================================
# Get API key from https://resend.com
RESEND_API_KEY=your_resend_api_key_here

# Email address to send from (must be verified in Resend)
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Email address to receive daily digests
CLIENT_EMAIL=admin@yourdomain.com

# ============================================
# Logging Configuration (OPTIONAL)
# ============================================
# Log levels: fatal, error, warn, info, debug, trace
LOG_LEVEL=info
SERVICE_NAME=attrakt

# ============================================
# Storage Configuration (OPTIONAL - for future file storage)
# ============================================
# S3-compatible storage (e.g., AWS S3, DigitalOcean Spaces, etc.)
STORAGE_ENDPOINT=https://s3.amazonaws.com
STORAGE_ACCESS_KEY_ID=your_storage_access_key_id
STORAGE_SECRET_ACCESS_KEY=your_storage_secret_access_key
STORAGE_BUCKET=your_storage_bucket_name
