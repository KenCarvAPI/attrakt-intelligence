# Attrakt Intelligence - Environment Variables
# =================================================================
# Copy this file to `.env` and fill in values:  cp .env.example .env
#
# This file is the single source of truth for configuration and is kept in
# sync with the Zod schema in packages/core/src/config.ts. Every variable the
# codebase reads (process.env.*) is documented below.
#
# Legend:
#   [REQUIRED]        Must be set for local dev to boot (DB + Redis).
#   [REQUIRED:PROD]   Must be set in production; has a safe default locally.
#   [FEATURE]         Only needed if you use that integration. Unset = feature
#                     is simply inactive locally (all are .optional() in config).
#   [OPTIONAL]        Has a sensible default; override only if needed.
# =================================================================


# ============================================
# Application
# ============================================
# [OPTIONAL] development | production | test  (default: development)
NODE_ENV=development
# [OPTIONAL] Tenant id used when no client is specified (default: default)
DEFAULT_CLIENT_ID=default
# [OPTIONAL] Port for the API / health server (default: 3001)
PORT=3001
# [OPTIONAL] Port for the GitHub webhook listener (default: 3002)
GITHUB_WEBHOOK_PORT=3002


# ============================================
# Database  — [REQUIRED]
# ============================================
# PostgreSQL connection string (TimescaleDB extension expected).
# Local default matches docker-compose.yml. Used by Prisma (DATABASE_URL).
# Where to get it (prod): your managed Postgres provider (Railway, Supabase,
# Neon, RDS). Must point at a database with the timescaledb extension enabled.
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://attrakt:attrakt_dev@localhost:5432/attrakt


# ============================================
# Redis  — [REQUIRED]
# ============================================
# Used for BullMQ queues and caching. Local default matches docker-compose.yml.
# Where to get it (prod): Railway/Upstash/Elasticache. With auth use
# redis://:password@host:port (or rediss:// for TLS).
REDIS_URL=redis://localhost:6379


# ============================================
# Discord  — [FEATURE]
# ============================================
# Needed for the Discord bot / discord-mcp. Create an application + bot at
# https://discord.com/developers/applications
# - Bot token: Application > Bot > Reset Token
# - Client id/secret: Application > OAuth2 > General
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=


# ============================================
# GitHub  — [FEATURE]
# ============================================
# Needed for github-mcp / webhook ingestion.
# Option 1 (simplest): a Personal Access Token.
#   https://github.com/settings/tokens  (repo + read:org scopes for orgs)
#   NOTE: config also accepts GITHUB_PAT as a fallback for this value.
GITHUB_TOKEN=
# Option 2: a GitHub App (use instead of GITHUB_TOKEN for higher rate limits).
#   https://github.com/settings/apps  ->  App ID + generated private key (PEM)
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
# Secret used to verify inbound webhook signatures (set the same value in the
# repo/org webhook settings).
GITHUB_WEBHOOK_SECRET=
# OAuth app credentials (only for user-facing "Login with GitHub").
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=


# ============================================
# Twitter / X  — [FEATURE]
# ============================================
# Needed for twitter-mcp / polling. https://developer.twitter.com (X Developer
# Portal) > Project > Keys and tokens.
TWITTER_BEARER_TOKEN=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
# [OPTIONAL] Comma-separated handles to track, e.g. acme,acme_support
TWITTER_TRACKED_ACCOUNTS=
# [OPTIONAL] Poll interval in ms (default: 900000 = 15 min)
TWITTER_POLL_INTERVAL_MS=900000


# ============================================
# Anthropic / Claude  — [FEATURE]
# ============================================
# Needed for the AI agents (Community Pulse, Threat Detection).
# Get a key at https://console.anthropic.com  (Settings > API Keys)
ANTHROPIC_API_KEY=


# ============================================
# Slack  — [FEATURE]
# ============================================
# Incoming webhook URL for alerts/notifications.
# https://api.slack.com/apps > Incoming Webhooks
SLACK_WEBHOOK_URL=


# ============================================
# Email (Resend)  — [FEATURE]
# ============================================
# Used to deliver daily digests and threat alerts.
# API key:    https://resend.com  (API Keys)
RESEND_API_KEY=
# Verified sender address (must be a verified domain in Resend).
RESEND_FROM_EMAIL=
# Recipient for digests/alerts.
CLIENT_EMAIL=


# ============================================
# Logging  — [OPTIONAL]
# ============================================
# fatal | error | warn | info | debug | trace  (default: info)
LOG_LEVEL=info
# Service name attached to structured logs (default: attrakt)
SERVICE_NAME=attrakt


# ============================================
# Storage (S3-compatible)  — [FEATURE]
# ============================================
# Reserved for future file/evidence storage (AWS S3, DO Spaces, R2, etc.).
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET=
